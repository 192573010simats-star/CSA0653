Minimum spanning Tree--Kruskal's algorithm

def find(p, i):
    if p[i] != i:
        p[i] = find(p, p[i])
    return p[i]

def kruskal(n, edges):
    edges.sort(key=lambda x: x[2])
    p = list(range(n))
    r = [0] * n
    mst = []
    cost = 0

    for u, v, w in edges:
        x = find(p, u)
        y = find(p, v)

        if x != y:
            mst.append((u, v, w))
            cost += w

            if r[x] < r[y]:
                p[x] = y
            elif r[x] > r[y]:
                p[y] = x
            else:
                p[y] = x
                r[x] += 1

    print("\nMST Edges:")
    for u, v, w in mst:
        print(u, "-", v, ":", w)

    print("Total Cost:", cost)



edges = [
    (0, 1, 10),
    (0, 2, 6),
    (0, 3, 5),
    (1, 3, 15),
    (2, 3, 4)
]

n = 4  # number of nodes

kruskal(n, edges)





    
